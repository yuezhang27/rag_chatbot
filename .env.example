# Azure OpenAI（对话 + Embedding），必填
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-02-01
# 可选：Embedding 维度缩减（text-embedding-3-large 默认 3072，可设为 1024 或 512）
# EMBEDDING_DIMENSIONS=3072

# 检索后端选择：local（默认，ChromaDB）或 azure（Azure AI Search）
# SEARCH_BACKEND=local
SEARCH_BACKEND=azure

# Azure AI Search（SEARCH_BACKEND=azure 时必填）
# AZURE_SEARCH_ENDPOINT=https://your-service.search.windows.net
# AZURE_SEARCH_API_KEY=your_admin_key_here
# AZURE_SEARCH_INDEX_NAME=hr-documents
# AZURE_SEARCH_SEMANTIC_CONFIG=hr-semantic-config

# Azure Blob Storage 对话存档（可选，不填则静默跳过）
# AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_BLOB_CONTAINER_NAME=conversation-logs

# LangSmith LLM 可观测性（可选，不填则不启用链路追踪）
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=rag-chatbot

# Azure Application Insights（可选，不填则静默跳过）
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Redis 语义缓存（可选，不填则不启用缓存）
# REDIS_URL=redis://redis:6379
# CACHE_SIMILARITY_THRESHOLD=0.95
# CACHE_ENABLED=true

# 双层 Guardrails（可选，不填则不启用 Content Safety 层）
# AZURE_CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_CONTENT_SAFETY_KEY=your_key_here
# GUARDRAILS_ENABLED=true

# Azure AI Language PII 检测（可选，不填则 PII 检测降级为无操作）
# AZURE_LANGUAGE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_LANGUAGE_KEY=your_key_here

# Azure Document Intelligence（--parser azure 时必填，用于提取表格密集型 PDF）
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_DOCUMENT_INTELLIGENCE_KEY=your_key_here
# 也兼容旧名：DOCINTELLIGENCE_ENDPOINT / DOCINTELLIGENCE_KEY
